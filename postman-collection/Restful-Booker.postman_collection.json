{
  "info": {
    "_postman_id": "e1b0c2d3-4f5a-6b7c-8d9e-0f1a2b3c4d5e",
    "name": "Restful-Booker API",
    "description": "Complete API collection for the Restful-Booker application (https://restful-booker.herokuapp.com).\n\nRequests are ordered for sequential execution.\nRun 'Create Token' first — it auto-saves {{authToken}}.\nRun 'Create Booking' next — it auto-saves {{bookingId}}.\n\nKnown API quirks are documented in each request's description.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://restful-booker.herokuapp.com",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1 – Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/ping",
          "host": ["{{baseUrl}}"],
          "path": ["ping"]
        },
        "description": "Confirms the API is up and running.\n\n⚠️ BUG: Returns 201 Created instead of 200 OK. Monitoring tools checking for 200 may false-alarm."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Health check returns 201 (known bug, should be 200)', function () {",
              "    pm.response.to.have.status(201);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2 – Create Token",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth",
          "host": ["{{baseUrl}}"],
          "path": ["auth"]
        },
        "description": "Generates an auth token for protected CRUD operations.\n\n⚠️ BUG: Returns HTTP 200 even for invalid credentials (returns {\"reason\":\"Bad credentials\"} instead of 401)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Response has a token', function () {",
              "    pm.expect(json).to.have.property('token');",
              "    pm.expect(json.token).to.be.a('string').and.not.empty;",
              "});",
              "if (json.token) {",
              "    pm.collectionVariables.set('authToken', json.token);",
              "    console.log('Auth token saved:', json.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "3 – Get All Bookings",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Accept", "value": "application/json" }
        ],
        "url": {
          "raw": "{{baseUrl}}/booking",
          "host": ["{{baseUrl}}"],
          "path": ["booking"]
        },
        "description": "Returns an array of booking ID objects. Supports optional query filters: ?firstname=&lastname=&checkin=&checkout="
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is a non-empty array', function () {",
              "    var body = pm.response.json();",
              "    pm.expect(body).to.be.an('array').that.is.not.empty;",
              "    pm.expect(body[0]).to.have.property('bookingid');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4 – Create Booking",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstname\": \"John\",\n  \"lastname\": \"Doe\",\n  \"totalprice\": 150,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2025-06-01\",\n    \"checkout\": \"2025-06-10\"\n  },\n  \"additionalneeds\": \"Breakfast\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/booking",
          "host": ["{{baseUrl}}"],
          "path": ["booking"]
        },
        "description": "Creates a new booking. The `additionalneeds` field is optional.\nPost-response script auto-saves the bookingid as {{bookingId}}."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Response has a numeric bookingid', function () {",
              "    pm.expect(json).to.have.property('bookingid');",
              "    pm.expect(json.bookingid).to.be.a('number');",
              "});",
              "pm.test('Returned booking data matches sent data', function () {",
              "    pm.expect(json.booking.firstname).to.eql('John');",
              "    pm.expect(json.booking.lastname).to.eql('Doe');",
              "    pm.expect(json.booking.totalprice).to.eql(150);",
              "    pm.expect(json.booking.depositpaid).to.eql(true);",
              "});",
              "if (json.bookingid) {",
              "    pm.collectionVariables.set('bookingId', json.bookingid);",
              "    console.log('Booking ID saved:', json.bookingid);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "5 – Get Booking by ID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Accept", "value": "application/json" }
        ],
        "url": {
          "raw": "{{baseUrl}}/booking/{{bookingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["booking", "{{bookingId}}"]
        },
        "description": "Fetches a single booking by ID.\n\n⚠️ BUG: 404 response body is plain text ('Not Found'), not JSON. JSON parsing on 404 will throw."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response contains booking fields', function () {",
              "    var body = pm.response.json();",
              "    pm.expect(body).to.have.property('firstname');",
              "    pm.expect(body).to.have.property('lastname');",
              "    pm.expect(body).to.have.property('totalprice');",
              "    pm.expect(body).to.have.property('bookingdates');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "6 – Update Booking (Full PUT)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" },
          { "key": "Cookie", "value": "token={{authToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstname\": \"Updated\",\n  \"lastname\": \"Guest\",\n  \"totalprice\": 275,\n  \"depositpaid\": false,\n  \"bookingdates\": {\n    \"checkin\": \"2025-09-01\",\n    \"checkout\": \"2025-09-15\"\n  },\n  \"additionalneeds\": \"Dinner\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/booking/{{bookingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["booking", "{{bookingId}}"]
        },
        "description": "Fully replaces a booking. Requires auth via Cookie token or Basic Auth.\n\n⚠️ BUG: Returns 403 (not 401) when no credentials are provided."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Booking was updated', function () {",
              "    var body = pm.response.json();",
              "    pm.expect(body.firstname).to.eql('Updated');",
              "    pm.expect(body.lastname).to.eql('Guest');",
              "    pm.expect(body.totalprice).to.eql(275);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "7 – Partial Update Booking (PATCH)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" },
          { "key": "Cookie", "value": "token={{authToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstname\": \"Patched\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/booking/{{bookingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["booking", "{{bookingId}}"]
        },
        "description": "Partially updates only the fields provided in the request body. Other fields unchanged."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Firstname was patched', function () {",
              "    pm.expect(pm.response.json().firstname).to.eql('Patched');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "8 – Delete Booking",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Cookie", "value": "token={{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/booking/{{bookingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["booking", "{{bookingId}}"]
        },
        "description": "Deletes a booking by ID. Requires auth.\n\n⚠️ BUG: Returns 201 Created instead of 200 OK or 204 No Content. 201 is semantically incorrect for a delete operation."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201 (known bug, should be 200 or 204)', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.collectionVariables.unset('bookingId');"
            ]
          }
        }
      ]
    }
  ]
}
